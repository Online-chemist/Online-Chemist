</html>*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Poppins,sans-serif;
}

body{
background:#f5f8fb;
color:#333;
}

header{
display:flex;
justify-content:space-between;
align-items:center;
padding:20px 8%;
background:#0077b6;
color:white;
}

.logo{
font-size:28px;
font-weight:bold;
}

nav a{
margin-left:25px;
color:white;
text-decoration:none;
}

.hero{
height:80vh;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
text-align:center;
padding:20px;
background:linear-gradient(#0077b6,#00b4d8);
color:white;
}

.hero h1{
font-size:55px;
margin-bottom:20px;
}

.hero p{
font-size:20px;
margin-bottom:30px;
max-width:700px;
}

.btn{
padding:15px 35px;
background:white;
color:#0077b6;
text-decoration:none;
font-weight:bold;
border-radius:30px;
}

section{
padding:70px 8%;
}

h2{
text-align:center;
margin-bottom:40px;
font-size:35px;
}

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:30px;
}

.card{
background:white;
padding:35px;
border-radius:15px;
box-shadow:0 10px 25px rgba(0,0,0,.1);
text-align:center;
}

.contact{
text-align:center;
background:#caf0f8;
}

.whatsapp{
display:inline-block;
margin-top:20px;
padding:15px 35px;
background:#25D366;
color:white;
text-decoration:none;
border-radius:40px;
}

footer{
background:#03045e;
color:white;
text-align:center;
padding:25px;
}<img src="logo.png" width="60" alt="Online Chemist Logo">
